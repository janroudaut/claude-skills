#!/bin/bash
# Post-edit hook: runs tests automatically after each Edit/Write.
# Receives Claude Code JSON input via stdin.
# - Non-code files (.md, .json, etc.) → ignored
# - Frontend files (views, JS, CSS, helpers) → unit + system tests
# - Backend files (models, services, controllers, etc.) → unit tests only
#
# Configurable variables:
#   TEST_CMD          — unit/integration test command (default: bin/rails test)
#   SYSTEM_TEST_CMD   — system test command (default: bin/rails test:system)

set -e

TEST_CMD="${TEST_CMD:-bin/rails test}"
SYSTEM_TEST_CMD="${SYSTEM_TEST_CMD:-bin/rails test:system}"

INPUT=$(cat)
FILE_PATH=$(echo "$INPUT" | jq -r '.tool_input.file_path // empty' 2>/dev/null)

# No file_path → nothing to do
[ -z "$FILE_PATH" ] && exit 0

# Ignore non-code files
case "$FILE_PATH" in
  *.md|*.json|*.yaml|*.yml|*.txt|*.lock|*.toml) exit 0 ;;
  */.claude/*|*/CLAUDE.md) exit 0 ;;
esac

# Determine if it's a frontend change
is_frontend=false
case "$FILE_PATH" in
  */app/views/*|*/app/javascript/*|*/app/assets/*|*/app/helpers/*)
    is_frontend=true ;;
esac

echo "🧪 Auto-tests ($(basename "$FILE_PATH"))..."

# Always run unit/integration tests
if ! $TEST_CMD 2>&1 | tail -8; then
  echo "❌ Unit tests failed"
  exit 0
fi

# System tests only for frontend changes
if [ "$is_frontend" = true ]; then
  echo "🖥️  System tests (frontend change)..."
  $SYSTEM_TEST_CMD 2>&1 | tail -8
fi

exit 0
