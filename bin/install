#!/bin/bash
# Install Claude Code skills into a target project.
#
# Usage:
#   bin/install [options] [project_path]
#
# Options:
#   --all       Install everything (skills + hook + template)
#   --skills    Install skills only
#   --hook      Install test-hook + settings.json
#   --template  Copy the CLAUDE.md template
#   (none)      Interactive mode
#
# If project_path is omitted, uses the current directory.

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
SKILLS_DIR="$SCRIPT_DIR/skills"
TEMPLATES_DIR="$SCRIPT_DIR/templates"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

info()  { echo -e "${BLUE}ℹ${NC}  $1"; }
ok()    { echo -e "${GREEN}✓${NC}  $1"; }
warn()  { echo -e "${YELLOW}⚠${NC}  $1"; }
error() { echo -e "${RED}✗${NC}  $1"; }

# --- Parse arguments ---

MODE=""
TARGET=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --all)      MODE="all"; shift ;;
    --skills)   MODE="skills"; shift ;;
    --hook)     MODE="hook"; shift ;;
    --template) MODE="template"; shift ;;
    -h|--help)
      echo "Usage: bin/install [--all|--skills|--hook|--template] [project_path]"
      echo ""
      echo "Options:"
      echo "  --all       Install everything (skills + hook + template)"
      echo "  --skills    Install skills only"
      echo "  --hook      Install test-hook + settings.json"
      echo "  --template  Copy the CLAUDE.md template"
      echo "  (none)      Interactive mode"
      exit 0
      ;;
    *)          TARGET="$1"; shift ;;
  esac
done

TARGET="${TARGET:-.}"
TARGET="$(cd "$TARGET" 2>/dev/null && pwd)" || { error "Directory '$TARGET' not found"; exit 1; }

echo ""
echo "╔══════════════════════════════════════╗"
echo "║   Claude Skills — Installation       ║"
echo "╚══════════════════════════════════════╝"
echo ""
info "Target project: $TARGET"
echo ""

# --- Helpers ---

confirm() {
  local msg="$1"
  read -r -p "$(echo -e "${YELLOW}?${NC}  $msg [y/N] ")" response
  [[ "$response" =~ ^[yY]$ ]]
}

safe_copy() {
  local src="$1"
  local dst="$2"
  local label="$3"

  if [ -f "$dst" ]; then
    if diff -q "$src" "$dst" > /dev/null 2>&1; then
      info "$label — already up to date"
      return 0
    fi
    if ! confirm "$label already exists. Overwrite?"; then
      warn "$label — skipped"
      return 0
    fi
  fi

  mkdir -p "$(dirname "$dst")"
  cp "$src" "$dst"
  ok "$label"
}

# --- Install functions ---

install_skills() {
  info "Installing skills..."
  echo ""

  for skill_dir in "$SKILLS_DIR"/*/; do
    skill_name="$(basename "$skill_dir")"
    safe_copy \
      "$skill_dir/SKILL.md" \
      "$TARGET/.claude/skills/$skill_name/SKILL.md" \
      "skills/$skill_name"
  done
  echo ""
}

install_hook() {
  info "Installing test hook..."
  echo ""

  safe_copy \
    "$SCRIPT_DIR/bin/test-hook" \
    "$TARGET/bin/test-hook" \
    "bin/test-hook"

  # Make executable
  chmod +x "$TARGET/bin/test-hook" 2>/dev/null || true

  safe_copy \
    "$TEMPLATES_DIR/settings.json" \
    "$TARGET/.claude/settings.json" \
    ".claude/settings.json"

  echo ""
}

install_template() {
  info "Installing CLAUDE.md template..."
  echo ""

  if [ -f "$TARGET/CLAUDE.md" ]; then
    warn "CLAUDE.md already exists in the project."
    warn "The template is available at: $TEMPLATES_DIR/CLAUDE.md"
    warn "Compare and manually integrate the relevant sections."
  else
    safe_copy \
      "$TEMPLATES_DIR/CLAUDE.md" \
      "$TARGET/CLAUDE.md" \
      "CLAUDE.md"
  fi
  echo ""
}

# --- Execution ---

case "$MODE" in
  all)
    install_skills
    install_hook
    install_template
    ;;
  skills)
    install_skills
    ;;
  hook)
    install_hook
    ;;
  template)
    install_template
    ;;
  "")
    # Interactive mode
    echo "What would you like to install?"
    echo ""
    echo "  1) Everything (skills + hook + template)"
    echo "  2) Skills only"
    echo "  3) Test hook + settings.json"
    echo "  4) CLAUDE.md template"
    echo "  5) Cancel"
    echo ""
    read -r -p "Choice [1-5]: " choice

    echo ""
    case "$choice" in
      1) install_skills; install_hook; install_template ;;
      2) install_skills ;;
      3) install_hook ;;
      4) install_template ;;
      5) info "Cancelled."; exit 0 ;;
      *) error "Invalid choice"; exit 1 ;;
    esac
    ;;
esac

echo "────────────────────────────────────────"
ok "Installation complete!"
echo ""
